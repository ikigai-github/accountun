{
  "name": "accountun",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {    
    "standalone": "docker compose stop && docker compose up -d",
    "testnet": "MIDNIGHT_NETWORK='testnet' docker compose up -d proof-server",
    "compile": "bun run --filter @accountun/contract --elide-lines=0 compile",
    "cli": "bun run --filter @accountun/cli --elide-lines=0 cli"
  }
}
