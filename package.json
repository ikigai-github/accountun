{
  "name": "accountun",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": "1.3.0"
  },
  "scripts": {
    "standalone": "docker compose stop && docker compose up -d",
    "testnet": "MIDNIGHT_NETWORK='testnet' docker compose up -d proof-server",
    "compile": "bun --filter @accountun/contract --elide-lines=0 compile",
    "fetch-zk-params": "bun ./scripts/fetch-zk-params.ts",
    "cli": "bun --filter @accountun/cli --elide-lines=0 cli"
  }
}
