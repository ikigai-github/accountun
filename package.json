{
  "name": "accountun",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": "1.3.8"
  },
  "scripts": {
    "clean": "find . -name node_modules -type d -prune -exec rm -rf {} + && rm -rf .cache ./packages/contract/managed && bun pm cache rm",
    "setup": "bun clean && bun install && bun run fetch-zk-params && bun run compile",
    "standalone": "docker compose stop && docker compose up -d",
    "testnet": "MIDNIGHT_NETWORK='testnet' docker compose up -d proof-server",
    "compile": "bun --filter @accountun/contract --elide-lines=0 compile",
    "fetch-zk-params": "docker compose down && bun ./scripts/fetch-zk-params.ts",
    "api": "./packages/api/index.ts",
    "cli": "./packages/cli/index.ts",
    "docker:build:proof": "docker build -t accountun.azurecr.io/accountun-proof-server:latest -f docker/proof-server.Dockerfile .",
    "docker:build:api": "docker build -t accountun-api:latest -f docker/api.Dockerfile .",
    "docker:build": "bun run docker:build:proof && bun run docker:build:api",
    "docker:push:proof": "docker push accountun.azurecr.io/accountun-proof-server:latest",
    "docker:push:api": "docker push accountun.azurecr.io/accountun-api:latest",
    "docker:push": "bun run docker:push:proof && bun run docker:push:api",
    "publish:api": "bun run docker:build:api && bun run docker:push:api",
    "publish:proof": "bun run docker:build:proof && bun run docker:push:proof",
    "test:unit": "bun --filter @accountun/common test && bun --filter @accountun/contract test",
    "test:integration": "NETWORK_MODE=local NETWORK=undeployed bun test ./packages/contract/test/integration --preload ./packages/contract/test/integration/setup.ts --timeout 1500000",
    "test:integration:wallet": "NETWORK_MODE=local NETWORK=undeployed bun test ./packages/contract/test/integration/wallet.integration.test.ts --preload ./packages/contract/test/integration/setup.ts --timeout 1500000",
    "test:integration:tournament": "NETWORK_MODE=local NETWORK=undeployed bun test ./packages/contract/test/integration/tournament.integration.test.ts --preload ./packages/contract/test/integration/setup.ts --timeout 1500000",
    "fund:local": "bun ./scripts/fund-local.ts",
    "health:local": "bun ./scripts/health-check.ts",
    "dust:register": "bun ./scripts/register-dust.ts"
  }
}
